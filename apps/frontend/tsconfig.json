{
  "extends": "@cushion/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@cushion/types": [
        "../../packages/types/src/index.ts"
      ],
      "@cushion/types/*": [
        "../../packages/types/src/*"
      ],
      "@opencode-ai/sdk/v2/client": [
        "./lib/opencode-sdk.ts"
      ],
      "@opencode-ai/sdk": [
        "../../opencode/packages/sdk/js/src/index.ts"
      ],
      "@opencode-ai/sdk/*": [
        "../../opencode/packages/sdk/js/src/*"
      ]
    },
    "isolatedModules": true
  },
  "references": [
    {
      "path": "../../packages/types"
    }
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
